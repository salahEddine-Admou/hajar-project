# Server
PORT=4100
NODE_ENV=development

# Auth — REQUIRED. The server refuses to start without it.
# Generate one with: openssl rand -hex 32  (or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=30d

# MongoDB connection string (MongoDB Atlas or local).
# Use a dedicated user with a STRONG password and restrict Atlas network access
# to known IPs rather than 0.0.0.0/0.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hajar?retryWrites=true&w=majority

# CORS — comma-separated list of allowed web origins in production
# (e.g. https://your-app.vercel.app). Leave empty to allow all (dev only).
CORS_ORIGINS=

# AI Assistant (optional). If omitted, a built-in rule-based assistant is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
